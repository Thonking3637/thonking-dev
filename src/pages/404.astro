---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout
  title="404 — esta página no está en el plano"
  description="La ruta que buscas no existe. Regresa al inicio de thonking.dev."
  path="/404"
  noindex
>
  <Navbar />
  <main id="main" class="min-h-screen grid place-items-center px-6 py-32 relative overflow-hidden">
    <!-- decorative giant 404 -->
    <div
      aria-hidden="true"
      class="pointer-events-none select-none absolute inset-0 flex items-center justify-center"
    >
      <span
        class="hero-stroke font-pixel text-[52vw] md:text-[30vw] leading-none tracking-tight opacity-[0.07]"
        >404</span
      >
    </div>

    <div class="relative text-center max-w-xl">
      <img
        src="/mascot/mascot-excited.webp"
        alt="Mascot Thonking pensando dónde fue la página"
        width="1200"
        height="1200"
        class="mx-auto w-48 md:w-56 h-auto float-mac"
        style="filter: drop-shadow(0 18px 30px rgba(26,24,21,0.22));"
      />

      <div
        class="mt-4 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-muted"
      >
        <span class="size-1.5 rounded-full bg-primary animate-pulse"></span>
        Error 404
      </div>

      <h1
        class="mt-3 font-display font-black text-5xl md:text-7xl leading-[0.9] tracking-[-0.03em]"
      >
        Esta página no<br />está en el plano.
      </h1>
      <p class="mt-5 text-muted text-lg leading-relaxed">
        La ruta que buscas no existe o la moví de sitio. El thonking tampoco
        sabe dónde quedó.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="group inline-flex items-center gap-2 rounded-full bg-primary text-ink px-5 py-3 font-semibold hover:scale-[1.03] transition-transform"
        >
          <svg
            class="size-4 transition-transform group-hover:-translate-x-0.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M19 12H5M11 19l-7-7 7-7" />
          </svg>
          Volver al inicio
        </a>
        <a
          href="mailto:gabriel@thonking.dev"
          class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-base-soft px-5 py-3 font-semibold hover:bg-base transition-colors"
        >
          Avísame del link roto
        </a>
      </div>
    </div>
  </main>
</Layout>
