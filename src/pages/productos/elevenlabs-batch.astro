---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ProductSchema from "../../components/ProductSchema.astro";
import ElevenLabsSlide from "../../components/ElevenLabsSlide.astro";

const product = await getEntry("products", "elevenlabs-batch");
if (!product) throw new Error("elevenlabs-batch product entry not found");
const { data } = product;

type ElevenSlideVariant = "config" | "picker" | "progress" | "output";
const slides: Array<{ id: string; variant: ElevenSlideVariant; label: string }> = [
  { id: "config", variant: "config", label: "Config de voz" },
  { id: "picker", variant: "picker", label: "File picker" },
  { id: "progress", variant: "progress", label: "Progress batch" },
  { id: "output", variant: "output", label: "Output folder" },
];

const stack = ["JavaScript", "ElevenLabs API", "itch.io"];

const howItWorks = [
  { title: "Procesamiento batch de múltiples archivos .txt", body: "Cargas una carpeta con decenas de textos. La tool detecta líneas, cuenta chars, y te muestra preview antes de procesar." },
  { title: "Output directo en formato OGG optimizado para Unity", body: "Mono, bitrate ajustado, nomenclatura por archivo. Listo para arrastrar a la carpeta Audio de tu proyecto Unity." },
  { title: "Configuración reutilizable de voz y parámetros", body: "Guardas presets de Voice ID, stability, similarity, style. Cambias de proyecto sin reconfigurar desde cero." },
  { title: "Requiere tu propia API key de ElevenLabs", body: "No cobro por usar ElevenLabs por ti. La tool es gratuita, tu uso contra tu cuota. Más transparente y barato para todos." },
  { title: "Publicado gratis en itch.io como pay-what-you-want", body: "Si te salvó 4 horas de trabajo, aporta lo que quieras. Si estás empezando, bajalo y ya. Sin friction." },
];

const lessons = [
  { icon: "wrench", text: "Las tools internas son producto público potencial. Si te ahorra 4h/semana a ti, probablemente a otros también." },
  { icon: "doc", text: "'Built for me' escala a 'built for many' si documentas bien. README claro = 80% del trabajo de onboarding." },
  { icon: "api", text: "ElevenLabs API es más flexible de lo que parece. El plan gratuito alcanza para demos, los parámetros avanzados cambian el juego." },
  { icon: "store", text: "itch.io como distro de tools dev funciona sorpresivamente bien. Nicho de gamedev compra/descarga ahí con naturalidad." },
];

const pageTitle = `${data.title} — Thonking`;
---

<Layout title={pageTitle} description={data.tagline} path={`/productos/${product.id}`}>
  <Navbar />
  <main id="main" class="relative pt-24 md:pt-28 pb-24 overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.08]" style="background-image: radial-gradient(circle, #1a1815 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div aria-hidden="true" class="pointer-events-none select-none absolute inset-x-0 top-28 flex justify-center">
      <span class="hero-stroke font-pixel text-[22vw] md:text-[14vw] leading-none tracking-tight opacity-[0.05]">BATCH</span>
    </div>

    <article class="relative mx-auto w-full max-w-[1200px] px-6 md:px-10">
      <a href="/productos" class="group inline-flex items-center gap-2 rounded-full border-2 border-ink/15 bg-base-soft px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80 hover:bg-secondary hover:border-ink hover:text-ink transition">
        <svg viewBox="0 0 40 32" class="size-5 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="#1a1815" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 4 L4 16 L14 28"></path><path d="M4 16 L36 16"></path><circle cx="4" cy="16" r="1.5" fill="#1a1815"></circle></svg>
        Volver a productos
      </a>

      <header class="mt-10 md:mt-12 relative grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-8 relative">
          <div class="inline-flex items-center gap-1.5 rounded-full border-2 border-ink text-ink px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] font-semibold shadow-[3px_3px_0_0_#1a1815]" style="background: #f4c430;">
            <span class="size-1.5 rounded-full bg-ink animate-pulse"></span>
            LIVE · v1.0
          </div>
          <h1 class="relative mt-6 font-display font-black text-[2.5rem] sm:text-5xl md:text-6xl lg:text-8xl xl:text-[7rem] leading-[0.9] tracking-[-0.04em]">
            ElevenLabs<br />
            <span class="relative inline-block pr-2">
              <span class="relative z-10 text-secondary">Batch</span>
              <svg aria-hidden="true" viewBox="0 0 110 110" class="absolute -top-6 md:-top-8 -right-10 md:-right-12 w-10 md:w-12 spin-slow rotate-[12deg]">
                <path d="M55 10 L66 42 L100 44 L72 64 L82 96 L55 78 L28 96 L38 64 L10 44 L44 42 Z" transform="translate(3 4)" fill="#1a1815" />
                <path d="M55 10 L66 42 L100 44 L72 64 L82 96 L55 78 L28 96 L38 64 L10 44 L44 42 Z" fill="#f4d35e" stroke="#1a1815" stroke-width="5" stroke-linejoin="round" />
              </svg>
              <svg aria-hidden="true" viewBox="0 0 480 40" class="absolute -bottom-2 left-0 w-full h-8 overflow-visible" preserveAspectRatio="none">
                <path class="draw-line" d="M4 22 C 100 6, 200 34, 280 18 S 440 6, 476 22" stroke="#f4d35e" stroke-width="14" stroke-linecap="round" fill="none" />
              </svg>
            </span>
          </h1>
          <p class="mt-8 text-lg md:text-xl text-muted leading-[1.7] max-w-2xl">
            Narrar audios para nuestros juegos de capacitación era un dolor — copiar texto por texto en ElevenLabs, exportar uno por uno, renombrar, importar a Unity. Construí una tool que procesa <span class="bg-secondary/25 px-1 rounded text-ink font-semibold">docenas de archivos en batch</span>, genera audios OGG optimizados para Unity, y los devuelve listos. <span class="bg-primary/15 px-1 rounded text-ink font-semibold">2 minutos en vez de 2 horas.</span>
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            {data.url && (
              <a href={data.url} target="_blank" rel="noopener" class="group inline-flex items-center gap-3 rounded-full bg-ink text-base-soft pl-7 pr-2.5 py-3 font-semibold text-lg md:text-xl transition-colors hover:text-ink" style="--hover-bg: #f4c430;" onmouseover="this.style.background='#f4c430'" onmouseout="this.style.background=''">
                Descargar en itch.io
                <span class="grid size-11 place-items-center rounded-full transition-colors" style="background: #f4c430; color: #1a1815;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M7 17L17 7M9 7h8v8" /></svg>
                </span>
              </a>
            )}
            <span class="font-mono text-xs uppercase tracking-[0.16em] text-muted">· Requiere cuenta ElevenLabs</span>
          </div>
        </div>
        <div class="lg:col-span-4 relative hidden lg:block" aria-hidden="true">
          <div class="absolute -top-6 -right-8 w-56 xl:w-64 rotate-[-6deg] float-mac pointer-events-none" style="filter: drop-shadow(0 18px 30px rgba(26,24,21,0.25));">
            <img src="/mascot/mascot-hero-happy.webp" alt="" width="1200" height="1200" class="w-full h-auto select-none" draggable="false" />
          </div>
        </div>
      </header>

      <!-- Hero visual: tool screen recording on branded stage -->
      <div class="relative mt-14 rounded-3xl border-2 border-ink overflow-hidden shadow-[0_30px_60px_-20px_rgba(26,24,21,0.3)]">
        <!-- Stage: dark yellow-tinted gradient bg -->
        <div
          class="absolute inset-0"
          style="background: radial-gradient(1000px 600px at 50% 40%, #2a2016, #0a0a0f);"
          aria-hidden="true"
        ></div>
        <!-- Grid pattern overlay -->
        <div
          class="absolute inset-0 opacity-[0.1]"
          style="background-image: linear-gradient(to right, #f4c430 1px, transparent 1px), linear-gradient(to bottom, #f4c430 1px, transparent 1px); background-size: 32px 32px;"
          aria-hidden="true"
        ></div>
        <!-- Giant outlined background type -->
        <div
          class="absolute inset-0 flex items-center justify-center pointer-events-none select-none"
          aria-hidden="true"
        >
          <span class="font-pixel font-bold text-[18vw] md:text-[12vw] leading-none tracking-tight text-[#f5f0e8]/10">BATCH</span>
        </div>

        <!-- Decorative sparkle top-left -->
        <svg
          aria-hidden="true"
          viewBox="0 0 100 100"
          class="absolute top-6 left-6 w-10 md:w-14 float-b"
        >
          <path
            d="M50 8 C 52 32 68 48 92 50 C 68 52 52 68 50 92 C 48 68 32 52 8 50 C 32 48 48 32 50 8 Z"
            fill="#f4c430"
            stroke="#1a1815"
            stroke-width="5"
            stroke-linejoin="round"
          />
        </svg>
        <!-- Decorative star bottom-right -->
        <svg
          aria-hidden="true"
          viewBox="0 0 110 110"
          class="absolute bottom-8 right-8 w-12 md:w-16 float-a rotate-[14deg]"
        >
          <path
            d="M55 10 L66 42 L100 44 L72 64 L82 96 L55 78 L28 96 L38 64 L10 44 L44 42 Z"
            fill="#f4c430"
            stroke="#1a1815"
            stroke-width="5"
            stroke-linejoin="round"
          />
        </svg>

        <!-- Video centered on stage with sticker shadow -->
        <div class="relative flex justify-center p-8 md:p-12">
          <video
            autoplay
            muted
            loop
            playsinline
            class="w-full aspect-video rounded-2xl border-2 border-[#1a1815] object-cover shadow-[6px_6px_0_0_#1a1815]"
          >
            <source src="/videos/elevenlabs-batch-clip.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

      <section class="mt-24 md:mt-28">
        <header class="mb-6">
          <div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"><span class="size-1.5 rounded-full" style="background: #f4c430;"></span>Galería</div>
          <h2 class="mt-4 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]">Un vistazo dentro</h2>
          <p class="mt-4 text-muted leading-[1.7] max-w-lg">El flow completo: config, picker, batch, output. Lo que ves es lo que hay.</p>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {slides.map((s) => (
            <button type="button" data-slide-open={s.id} aria-label={`Abrir preview: ${s.label}`} class="group relative aspect-[3/4] rounded-2xl border-2 border-ink/20 overflow-hidden hover:-translate-y-1 hover:shadow-[0_18px_36px_-12px_rgba(26,24,21,0.45)] hover:border-ink cursor-zoom-in transition-all" style="--slide-pad: 14px; --slide-meta: 7px; --slide-sub: 12px; --slide-body: 6.5px; --slide-footer: 6px; --slide-gap-sm: 3px; --slide-bar-h: 3px;">
              <ElevenLabsSlide variant={s.variant} />
              <div class="absolute top-2 right-2 size-7 grid place-items-center rounded-full bg-secondary text-ink border-2 border-ink opacity-0 group-hover:opacity-100 transition translate-y-1 group-hover:translate-y-0"><svg viewBox="0 0 24 24" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /><path d="M11 8v6M8 11h6" /></svg></div>
            </button>
          ))}
        </div>
      </section>

      {slides.map((s) => (
        <dialog data-slide={s.id} class="gdd-dialog relative w-[min(92vw,720px)] max-h-[92vh] p-0 m-auto rounded-3xl border-[3px] border-ink bg-[#0a0a0f] text-[#f5f0e8] backdrop:bg-ink/80 backdrop:backdrop-blur-sm overflow-hidden" aria-label={`Preview: ${s.label}`}>
          <div class="relative aspect-[3/4] w-full" style="--slide-pad: 30px; --slide-meta: 13px; --slide-sub: 26px; --slide-body: 13px; --slide-footer: 11px; --slide-gap-sm: 7px; --slide-bar-h: 7px;">
            <ElevenLabsSlide variant={s.variant} />
          </div>
          <button type="button" data-slide-close aria-label="Cerrar preview" class="absolute top-4 right-4 grid size-11 place-items-center rounded-full bg-secondary text-ink border-2 border-ink shadow-[3px_3px_0_0_#1a1815] hover:bg-primary hover:text-base-soft transition-colors"><svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" /></svg></button>
        </dialog>
      ))}

      <div id="problema" class="mt-24 md:mt-28 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 scroll-mt-28">
        <div class="lg:col-span-8 space-y-20 md:space-y-24">
          <section>
            <header class="mb-6"><div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"><span class="size-1.5 rounded-full" style="background: #f4c430;"></span>§ 01 · El problema</div>
              <h2 class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]">El workflow escondido del voice-over en gamedev</h2>
            </header>
            <div class="space-y-5 text-lg text-muted leading-[1.7] max-w-2xl">
              <p>Cuando tu juego tiene <strong class="text-ink font-semibold">100+ líneas de diálogo</strong>, el proceso manual de generar cada audio se vuelve el cuello de botella. ElevenLabs es increíble pero su UI web está pensada para generar audios uno a uno.</p>
              <p>La tool que construí asume que <strong class="text-ink font-semibold">ya sabes lo que quieres</strong> — dale la lista de textos, la config de voz, y que trabaje. Cero UI decorativa, cero upsells, cero distracciones.</p>
              <p>Empezó como tool interna para los juegos de capacitación. Lo publiqué en itch.io porque asumí que otros devs tendrían el mismo dolor. Tenía razón.</p>
            </div>
          </section>

          <section>
            <header class="mb-8"><div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"><span class="size-1.5 rounded-full bg-primary"></span>§ 02 · Qué hay adentro</div>
              <h2 class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]">Lo que trae la tool</h2>
            </header>
            <ol class="divide-y-2 divide-secondary/20">
              {howItWorks.map((step, i) => (
                <li class="grid grid-cols-[auto_1fr] gap-x-3 md:gap-x-4 py-8 md:py-10 first:pt-0 last:pb-0">
                  <div class="font-display font-black text-5xl md:text-6xl leading-[0.9] text-primary tabular-nums tracking-[-0.04em]">{String(i + 1).padStart(2, "0")}</div>
                  <div class="pt-1"><h3 class="font-display font-bold text-xl md:text-2xl leading-tight tracking-tight">{step.title}</h3><p class="mt-2 text-base md:text-lg text-muted leading-[1.6] max-w-lg">{step.body}</p></div>
                </li>
              ))}
            </ol>
          </section>

          <section>
            <header class="mb-10 flex items-end gap-5">
              <div class="flex-1"><div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"><span class="size-1.5 rounded-full bg-pink"></span>§ 03 · Lecciones</div>
                <h2 class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]">Lo que aprendí <span class="relative inline-block">shippeando<svg aria-hidden="true" viewBox="0 0 300 16" preserveAspectRatio="none" class="absolute -bottom-1 left-0 w-full h-3"><path d="M2 10 C 60 2, 140 14, 220 6 S 296 2, 298 12" stroke="#e8546f" stroke-width="5" stroke-linecap="round" fill="none" /></svg></span></h2>
              </div>
              <div class="shrink-0 hidden sm:block" aria-hidden="true"><img src="/mascot/mascot-idle.webp" alt="" width="1200" height="1200" class="w-20 md:w-24 h-auto float-mac" draggable="false" style="filter: drop-shadow(0 8px 14px rgba(26,24,21,0.22));" /></div>
            </header>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {lessons.map((lesson, i) => (
                <li class="relative rounded-2xl border-2 border-ink/10 bg-base-soft p-6 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_-12px_rgba(26,24,21,0.25)] transition-all">
                  <div class="flex items-start gap-5">
                    <div class="shrink-0 grid size-11 place-items-center rounded-xl border-2 border-ink shadow-[3px_3px_0_0_#1a1815]" style="background: #f4c430;">
                      {lesson.icon === "wrench" && <svg viewBox="0 0 24 24" class="size-5" fill="#1a1815" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4a4 4 0 0 1 6 5l-9 9-4 1 1-4 9-9-3-2Z" /></svg>}
                      {lesson.icon === "doc" && <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2" fill="#ffe8d4" /><path d="M9 9h6M9 13h6M9 17h4" /></svg>}
                      {lesson.icon === "api" && <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6" width="16" height="12" rx="2" fill="#ffe8d4" /><path d="M8 10h2v4H8zM12 10h4M12 14h3" /></svg>}
                      {lesson.icon === "store" && <svg viewBox="0 0 24 24" class="size-5" fill="#ffe8d4" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l2-5h14l2 5" /><path d="M3 8v12h18V8" /><path d="M9 20v-5h6v5" fill="none" /></svg>}
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted tabular-nums">{String(i + 1).padStart(2, "0")} / {String(lessons.length).padStart(2, "0")}</div>
                      <p class="mt-3 text-base md:text-[17px] leading-[1.6] text-ink">{lesson.text}</p>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        </div>

        <aside class="lg:col-span-4 lg:sticky lg:top-28 lg:self-start space-y-6">
          <div class="rounded-3xl border-2 border-ink bg-ink text-base-soft p-6 relative overflow-hidden">
            <div aria-hidden="true" class="absolute inset-0 opacity-10" style="background-image: linear-gradient(to right, #f4c430 1px, transparent 1px), linear-gradient(to bottom, #f4c430 1px, transparent 1px); background-size: 24px 24px;"></div>
            <div class="relative">
              <div class="font-mono text-[10px] uppercase tracking-[0.2em]" style="color: #f4c430;">● Live · Tool interna + pública</div>
              <div class="mt-3 font-display font-black text-6xl md:text-7xl leading-none tracking-[-0.04em]">v1.0</div>
              <div class="mt-2 font-mono text-xs uppercase tracking-[0.16em] text-base-soft/70">ElevenLabs API · batch</div>
              <div class="mt-4 pt-4 border-t border-base-soft/20 font-mono text-[10px] uppercase tracking-[0.16em] text-base-soft/60">Pay-what-you-want · itch.io</div>
            </div>
          </div>

          <div class="rounded-3xl border-2 border-ink/10 bg-base-soft p-6">
            <div class="flex items-center gap-2 mb-4"><svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="5" rx="1" /><rect x="3" y="10" width="18" height="5" rx="1" /><rect x="3" y="16" width="18" height="5" rx="1" /></svg><h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink font-semibold">Stack</h3></div>
            <ul class="flex flex-wrap gap-2">{stack.map((s) => <li class="rounded-full border border-ink/20 bg-base-soft/80 px-3 py-1 font-mono text-xs uppercase tracking-[0.14em] text-ink">{s}</li>)}</ul>
          </div>

          <div class="rounded-3xl border-2 border-ink/10 bg-base-soft p-6">
            <div class="flex items-center gap-2 mb-4"><svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12l-8 8a2 2 0 0 1-3 0L3 14a2 2 0 0 1 0-3l8-8h8v8Z" /><circle cx="15" cy="9" r="1.5" fill="#1a1815" /></svg><h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink font-semibold">Tags</h3></div>
            <ul class="flex flex-wrap gap-2">{data.tags.map((t) => <li class="rounded-full border border-dashed border-ink/30 px-3 py-1 font-mono text-xs uppercase tracking-[0.14em] text-ink/70">{t}</li>)}</ul>
          </div>
        </aside>
      </div>

      <section class="mt-24 md:mt-24 relative">
        <div class="relative rounded-3xl border-2 border-ink text-ink overflow-hidden shadow-[8px_8px_0_0_#1a1815]" style="background: #f4c430;">
          <div aria-hidden="true" class="absolute inset-0 opacity-[0.14]" style="background-image: linear-gradient(to right, #1a1815 1px, transparent 1px), linear-gradient(to bottom, #1a1815 1px, transparent 1px); background-size: 32px 32px;"></div>
          <div class="relative grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 md:gap-10 items-center px-8 md:px-12 py-12 md:py-16">
            <div>
              <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink/70">Pay-what-you-want · itch.io</div>
              <h2 class="mt-4 font-display font-black text-4xl md:text-5xl lg:text-6xl leading-[0.92] tracking-[-0.035em]">Descarga ElevenLabs Batch<br />gratis en itch.io</h2>
              <div class="mt-8 flex flex-wrap items-center gap-4">
                {data.url && (
                  <a href={data.url} target="_blank" rel="noopener" class="group inline-flex items-center gap-3 rounded-full bg-ink text-base-soft pl-6 pr-2 py-2.5 font-display font-bold text-lg md:text-xl hover:bg-primary transition-colors">
                    Ver en itch.io
                    <span class="grid size-11 place-items-center rounded-full bg-primary text-ink group-hover:bg-secondary group-hover:text-ink transition-colors"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="size-5"><path d="M12 5v14M5 12l7 7 7-7" /></svg></span>
                  </a>
                )}
              </div>
              <div class="mt-5 font-mono text-xs md:text-sm uppercase tracking-[0.16em] text-ink/70">Requiere tu propia API key · Cero costo de la tool</div>
            </div>
            <div class="justify-self-center md:justify-self-end shrink-0" aria-hidden="true">
              <div class="relative">
