---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ProductSchema from "../../components/ProductSchema.astro";
import RevertSlide from "../../components/RevertSlide.astro";

const product = await getEntry("products", "revert-pong");
if (!product) throw new Error("revert-pong product entry not found");
const { data } = product;

type RevertSlideVariant = "title" | "gameplay" | "blackhole" | "credits";

const slides: Array<{
  id: string;
  variant: RevertSlideVariant;
  label: string;
}> = [
  { id: "title", variant: "title", label: "Title screen" },
  { id: "gameplay", variant: "gameplay", label: "Gameplay · meteoros" },
  { id: "blackhole", variant: "blackhole", label: "Agujero negro" },
  { id: "credits", variant: "credits", label: "Créditos" },
];

const howItWorks = [
  {
    title: "Pong clásico con física realista",
    body: "Base mecánica pulida antes de cualquier twist. Sin buen feel de paleta y pelota, todo lo demás es decoración.",
  },
  {
    title: "Meteoros procedurales que alteran trayectorias",
    body: "Spawn basado en tiempo de juego. La pelota choca con ellos y cambia vector. Primera vez que implementé física emergente.",
  },
  {
    title: "Agujeros negros con campo gravitacional visible",
    body: "Zonas de atracción radial con feedback visual (partículas, distorsión). Solo aparecen tras 60 segundos de juego.",
  },
  {
    title: "Sistema de planetas que colapsan",
    body: "Elementos decorativos activos — los planetas del fondo colapsan progresivamente creando eventos visuales sin afectar gameplay.",
  },
  {
    title: "Modo arcade con dificultad progresiva",
    body: "Cada 30 segundos incrementa velocidad y spawn de elementos. Inspirado directamente en arcades de los 80s.",
  },
];

const lessons = [
  {
    icon: "coin",
    text: "Cobrar por tu trabajo cambia cómo ves el código que escribes. Menos 'hack and pray', más 'esto tiene que durar'.",
  },
  {
    icon: "chat",
    text: "Un cliente real te enseña más que 100 tutoriales. Negociar scope, defender decisiones, explicar por qué algo toma 2 semanas.",
  },
  {
    icon: "crop",
    text: "Scope creep existe desde el día uno. Empezamos con Pong + meteoros, terminamos con agujeros negros y planetas. Aprendí a decir 'eso es fase 2'.",
  },
  {
    icon: "ship",
    text: "Entregar un juego completo vale más que prototipar 10. Tengo carpetas de prototipos. Revert Pong es el único que terminé — y el que abrió puertas reales.",
  },
];

const pageTitle = `${data.title} — Thonking`;
---

<Layout
  title={pageTitle}
  description={data.tagline}
  path={`/productos/${product.id}`}
>
  <Navbar />

  <main id="main" class="relative pt-24 md:pt-28 pb-24 overflow-hidden">
    <!-- Background dot pattern -->
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 opacity-[0.08]"
      style="background-image: radial-gradient(circle, #1a1815 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>

    <!-- Giant faded background type -->
    <div
      aria-hidden="true"
      class="pointer-events-none select-none absolute inset-x-0 top-28 flex justify-center"
    >
      <span
        class="hero-stroke font-pixel text-[26vw] md:text-[16vw] leading-none tracking-tight opacity-[0.05]"
        >PONG</span
      >
    </div>

    <article class="relative mx-auto w-full max-w-[1200px] px-6 md:px-10">
      <!-- ========== BREADCRUMB ========== -->
      <a
        href="/productos"
        class="group inline-flex items-center gap-2 rounded-full border-2 border-ink/15 bg-base-soft px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/80 hover:bg-secondary hover:border-ink hover:text-ink transition"
      >
        <svg
          viewBox="0 0 40 32"
          class="size-5 transition-transform group-hover:-translate-x-0.5"
          fill="none"
          stroke="#1a1815"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 4 L4 16 L14 28"></path>
          <path d="M4 16 L36 16"></path>
          <circle cx="4" cy="16" r="1.5" fill="#1a1815"></circle>
        </svg>
        Volver a productos
      </a>

      <!-- ========== HERO ========== -->
      <header
        class="mt-10 md:mt-12 relative grid grid-cols-1 lg:grid-cols-12 gap-8 items-start"
      >
        <div class="lg:col-span-8 relative">
          <!-- Status pill -->
          <div
            class="inline-flex items-center gap-1.5 rounded-full border-2 border-ink bg-ink text-base-soft px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] font-semibold shadow-[3px_3px_0_0_#1a1815]"
          >
            <span class="size-1.5 rounded-full bg-primary"></span>
            Comercial · Vendido 2017
          </div>

          <!-- Title — 24px from badge -->
          <h1
            class="relative mt-6 font-display font-black text-[2.75rem] sm:text-6xl md:text-7xl lg:text-[7.5rem] xl:text-[9rem] leading-[0.88] tracking-[-0.04em]"
          >
            Revert<br />
            <span class="relative inline-block pr-2">
              <span class="relative z-10 text-secondary">Pong</span>
              <!-- Star anchored to title word -->
              <svg
                aria-hidden="true"
                viewBox="0 0 110 110"
                class="absolute -top-6 md:-top-8 -right-10 md:-right-12 w-10 md:w-12 spin-slow rotate-[12deg]"
              >
                <path
                  d="M55 10 L66 42 L100 44 L72 64 L82 96 L55 78 L28 96 L38 64 L10 44 L44 42 Z"
                  transform="translate(3 4)"
                  fill="#1a1815"></path>
                <path
                  d="M55 10 L66 42 L100 44 L72 64 L82 96 L55 78 L28 96 L38 64 L10 44 L44 42 Z"
                  fill="#f4d35e"
                  stroke="#1a1815"
                  stroke-width="5"
                  stroke-linejoin="round"></path>
              </svg>
              <svg
                aria-hidden="true"
                viewBox="0 0 480 40"
                class="absolute -bottom-2 left-0 w-full h-8 overflow-visible"
                preserveAspectRatio="none"
              >
                <path
                  class="draw-line"
                  d="M4 22 C 100 6, 200 34, 280 18 S 440 6, 476 22"
                  stroke="#f4d35e"
                  stroke-width="14"
                  stroke-linecap="round"
                  fill="none"
                />
              </svg>
            </span>
          </h1>

          <!-- Bio — 32px from title -->
          <p class="mt-8 text-lg md:text-xl text-muted leading-[1.7] max-w-2xl">
            Mi primer juego
            <span class="bg-primary/15 px-1 rounded text-ink font-semibold"
              >vendido comercialmente</span
            >. Una empresa peruana me contrató
            <span class="bg-secondary/25 px-1 rounded text-ink font-semibold"
              >a los 18 años</span
            > para crear un Pong remix con twist físico — meteoros, agujeros
            negros y planetas colapsando en tiempo real. Lo entregué y cobré
            mi primer cheque de gamedev. Ese día supe que esto era lo mío.
          </p>

          <!-- CTAs — 32px from bio -->
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a
              href="#problema"
              class="group inline-flex items-center gap-3 rounded-full bg-ink text-base-soft pl-7 pr-2.5 py-3 font-semibold text-lg md:text-xl hover:bg-primary transition-colors"
            >
              Ver detalles
              <span
                class="grid size-11 place-items-center rounded-full bg-primary text-ink group-hover:bg-ink transition-colors"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-4"
                >
                  <path d="M12 5v14M5 12l7 7 7-7"></path>
                </svg>
              </span>
            </a>
            {
              data.url && (
                <a
                  href={data.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-full border-2 border-ink/15 bg-base-soft px-5 py-3 font-mono text-xs uppercase tracking-[0.14em] font-semibold hover:bg-secondary hover:border-ink transition"
                >
                  Demo pública en itch.io
                  <svg
                    viewBox="0 0 24 24"
                    class="size-3.5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M7 17L17 7M9 7h8v8" />
                  </svg>
                </a>
              )
            }
          </div>
        </div>

        <!-- Peeking mascot idle (proyecto histórico) -->
        <div
          class="lg:col-span-4 relative hidden lg:block"
          aria-hidden="true"
        >
          <div
            class="absolute -top-6 -right-8 w-56 xl:w-64 rotate-[-6deg] float-mac pointer-events-none"
            style="filter: drop-shadow(0 18px 30px rgba(26,24,21,0.25));"
          >
            <img
              src="/mascot/mascot-hero-idle.webp"
              alt=""
              width="1200"
              height="1200"
              class="w-full h-auto select-none"
              draggable="false"
            />
          </div>
        </div>
      </header>

      <!-- ========== HERO VISUAL ========== -->
      <div
        class="mt-14 relative aspect-[16/9] rounded-3xl border-2 border-ink overflow-hidden shadow-[0_30px_60px_-20px_rgba(26,24,21,0.3)]"
      >
        <div
          class="absolute inset-0 overflow-hidden"
          style="background: radial-gradient(800px 500px at 50% 50%, #1b1040, #08051a);"
        >
          {/* stars */}
          {
            Array.from({ length: 70 }).map((_, i) => {
              const x = (i * 137) % 100;
              const y = (i * 61) % 100;
              const s = (i % 3) + 1;
              return (
                <div
                  class="absolute rounded-full bg-base-soft"
                  style={`left: ${x}%; top: ${y}%; width: ${s}px; height: ${s}px; opacity: ${0.4 + (i % 4) * 0.15};`}
                />
              );
            })
          }
          {/* center meteor */}
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
          >
            <div
              class="size-28 md:size-40 rounded-full"
              style="background: radial-gradient(circle, #ff6b4a, #c93a3a 60%, #7a1f1f 100%); box-shadow: 0 0 80px #ff6b4a, -50px 0 100px #ff6b4a80;"
            >
            </div>
            <div
              class="absolute right-full top-1/2 -translate-y-1/2 h-2 w-56 rounded-full"
              style="background: linear-gradient(to right, transparent, #ff6b4a);"
              aria-hidden="true"
            >
            </div>
          </div>
          {/* label overlay */}
          <div
            class="absolute bottom-6 left-6 font-pixel font-bold text-base-soft tracking-[0.1em] text-3xl md:text-5xl"
          >
            REVERT<span class="text-[#ff6b4a]"> PONG</span>
          </div>
          <div
            class="absolute bottom-6 right-6 font-mono text-xs uppercase tracking-[0.2em] text-base-soft/60"
          >
            2017 · Unity · Pixel Art
          </div>
        </div>
      </div>

      <!-- ========== GALLERY ========== -->
      <section class="mt-24 md:mt-28">
        <header class="mb-6">
          <div
            class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"
          >
            <span class="size-1.5 rounded-full bg-primary"></span>
            Galería
          </div>
          <h2
            class="mt-4 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]"
          >
            Un vistazo dentro
          </h2>
          <p class="mt-4 text-muted leading-[1.7] max-w-lg">
            Mockups editoriales. El juego vive en los servidores del cliente —
            éstas son reconstrucciones visuales de pantallas clave.
          </p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            slides.map((s) => (
              <button
                type="button"
                data-slide-open={s.id}
                aria-label={`Abrir preview: ${s.label}`}
                class="group relative aspect-[3/4] rounded-2xl border-2 border-ink/20 overflow-hidden hover:-translate-y-1 hover:shadow-[0_18px_36px_-12px_rgba(26,24,21,0.45)] hover:border-ink cursor-zoom-in transition-all"
                style="--slide-pad: 14px; --slide-meta: 7px; --slide-title: 24px; --slide-body: 7px; --slide-footer: 6px; --slide-gap-sm: 3px; --slide-sub: 10px; --slide-bh: 100px; --slide-paddle-w: 3px; --slide-paddle-h: 28px; --slide-ball: 5px; --slide-meteor: 7px; --slide-meteor-sm: 5px; --slide-meteor-trail: 10px; --slide-meteor-trail-sm: 8px;"
              >
                <RevertSlide variant={s.variant} />
                <div class="absolute top-2 right-2 size-7 grid place-items-center rounded-full bg-secondary text-ink border-2 border-ink opacity-0 group-hover:opacity-100 transition translate-y-1 group-hover:translate-y-0">
                  <svg
                    viewBox="0 0 24 24"
                    class="size-3.5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4.3-4.3" />
                    <path d="M11 8v6M8 11h6" />
                  </svg>
                </div>
              </button>
            ))
          }
        </div>
      </section>

      <!-- Lightbox dialogs -->
      {
        slides.map((s) => (
          <dialog
            data-slide={s.id}
            class="gdd-dialog relative w-[min(92vw,720px)] max-h-[92vh] p-0 m-auto rounded-3xl border-[3px] border-ink bg-[#08051a] text-base-soft backdrop:bg-ink/80 backdrop:backdrop-blur-sm overflow-hidden"
            aria-label={`Preview: ${s.label}`}
          >
            <div
              class="relative aspect-[3/4] w-full"
              style="--slide-pad: 36px; --slide-meta: 13px; --slide-title: 64px; --slide-body: 15px; --slide-footer: 11px; --slide-gap-sm: 8px; --slide-sub: 26px; --slide-bh: 280px; --slide-paddle-w: 8px; --slide-paddle-h: 78px; --slide-ball: 14px; --slide-meteor: 20px; --slide-meteor-sm: 14px; --slide-meteor-trail: 28px; --slide-meteor-trail-sm: 20px;"
            >
              <RevertSlide variant={s.variant} />
            </div>
            <button
              type="button"
              data-slide-close
              aria-label="Cerrar preview"
              class="absolute top-4 right-4 grid size-11 place-items-center rounded-full bg-secondary text-ink border-2 border-ink shadow-[3px_3px_0_0_#1a1815] hover:bg-primary hover:text-base-soft transition-colors"
            >
              <svg
                viewBox="0 0 24 24"
                class="size-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M18 6L6 18M6 6l12 12" />
              </svg>
            </button>
          </dialog>
        ))
      }

      <!-- ========== MAIN 2-COL BODY ========== -->
      <div
        id="problema"
        class="mt-24 md:mt-28 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 scroll-mt-28"
      >
        <div class="lg:col-span-8 space-y-20 md:space-y-24">
          <!-- El problema -->
          <section>
            <header class="mb-6">
              <div
                class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"
              >
                <span class="size-1.5 rounded-full bg-primary"></span>
                § 01 · El momento
              </div>
              <h2
                class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]"
              >
                Lo que nadie te cuenta de cobrar por tu primer juego
              </h2>
            </header>
            <div class="space-y-5 text-lg text-muted leading-[1.7] max-w-2xl">
              <p>
                <strong class="text-ink font-semibold">A los 18 años</strong>
                no tenía portfolio, ni red de contactos, ni idea de cómo
                funcionaba un contrato. Pero tenía un cliente real que quería
                un juego. Lo negocié, lo entregué, y aprendí más en esos meses
                que en dos años de tutoriales.
              </p>
              <p>
                Este juego
                <strong class="text-ink font-semibold">
                  no está en itch.io ni en ninguna store pública
                </strong>
                — vive en los servidores de la empresa que lo compró. La única
                versión accesible es la demo técnica. Pero fue
                <strong class="text-ink font-semibold">el punto de partida</strong>
                que abrió todas las puertas que vinieron después.
              </p>
              <p>
                9 años después sigo usando cosas que aprendí construyendo
                Revert Pong: cómo hacer que la física emergente se sienta
                intencional, cómo decir "eso es fase 2" sin perder al cliente,
                y por qué
                <strong class="text-ink font-semibold">
                  terminar un proyecto vale más que empezar diez
                </strong>.
              </p>
            </div>
          </section>

          <!-- Qué hay adentro -->
          <section>
            <header class="mb-8">
              <div
                class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"
              >
                <span class="size-1.5 rounded-full bg-secondary"></span>
                § 02 · Qué hay adentro
              </div>
              <h2
                class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]"
              >
                Qué construí
              </h2>
            </header>
            <ol class="divide-y-2 divide-secondary/20">
              {
                howItWorks.map((step, i) => (
                  <li class="grid grid-cols-[auto_1fr] gap-x-3 md:gap-x-4 py-8 md:py-10 first:pt-0 last:pb-0">
                    <div class="font-display font-black text-5xl md:text-6xl leading-[0.9] text-primary tabular-nums tracking-[-0.04em]">
                      {String(i + 1).padStart(2, "0")}
                    </div>
                    <div class="pt-1">
                      <h3 class="font-display font-bold text-xl md:text-2xl leading-tight tracking-tight">
                        {step.title}
                      </h3>
                      <p class="mt-2 text-base md:text-lg text-muted leading-[1.6] max-w-lg">
                        {step.body}
                      </p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </section>

          <!-- Lecciones aprendidas -->
          <section>
            <header class="mb-10 flex items-end gap-5">
              <div class="flex-1">
                <div
                  class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"
                >
                  <span class="size-1.5 rounded-full bg-pink"></span>
                  § 03 · Lecciones
                </div>
                <h2
                  class="mt-3 font-display font-black text-4xl md:text-5xl leading-[0.95] tracking-[-0.02em]"
                >
                  Lo que aprendí <span class="relative inline-block">
                    a los 18
                    <svg
                      aria-hidden="true"
                      viewBox="0 0 260 16"
                      preserveAspectRatio="none"
                      class="absolute -bottom-1 left-0 w-full h-3"
                    >
                      <path
                        d="M2 10 C 60 2, 140 14, 220 6 S 256 2, 258 12"
                        stroke="#e8546f"
                        stroke-width="5"
                        stroke-linecap="round"
                        fill="none"
                      />
                    </svg>
                  </span>
                </h2>
              </div>
              <div class="shrink-0 hidden sm:block" aria-hidden="true">
                <img
                  src="/mascot/mascot-idle.webp"
                  alt=""
                  width="1200"
                  height="1200"
                  class="w-20 md:w-24 h-auto float-mac"
                  draggable="false"
                  style="filter: drop-shadow(0 8px 14px rgba(26,24,21,0.22));"
                />
              </div>
            </header>

            <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {
                lessons.map((lesson, i) => (
                  <li class="relative rounded-2xl border-2 border-ink/10 bg-base-soft p-6 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_-12px_rgba(26,24,21,0.25)] transition-all">
                    <div class="flex items-start gap-5">
                      <div class="shrink-0 grid size-11 place-items-center rounded-xl border-2 border-ink bg-primary shadow-[3px_3px_0_0_#1a1815]">
                        {lesson.icon === "coin" && (
                          <svg viewBox="0 0 24 24" class="size-5" fill="#f4d35e" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="9" />
                            <path d="M12 7v10M15 10a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3" fill="none" />
                          </svg>
                        )}
                        {lesson.icon === "chat" && (
                          <svg viewBox="0 0 24 24" class="size-5" fill="#f4d35e" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8l-5 4Z" />
                          </svg>
                        )}
                        {lesson.icon === "crop" && (
                          <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 2v14a2 2 0 0 0 2 2h14" />
                            <path d="M18 6H8a2 2 0 0 0-2 2v14" />
                            <rect x="8" y="8" width="10" height="10" fill="#f4d35e" />
                          </svg>
                        )}
                        {lesson.icon === "ship" && (
                          <svg viewBox="0 0 24 24" class="size-5" fill="#f4d35e" stroke="#1a1815" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 3h14l-2 6H7Z" />
                            <path d="M4 9h16l-2 8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2Z" />
                            <path d="M9 13l2 2 4-4" fill="none" />
                          </svg>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted tabular-nums">
                          {String(i + 1).padStart(2, "0")} /{" "}
                          {String(lessons.length).padStart(2, "0")}
                        </div>
                        <p class="mt-3 text-base md:text-[17px] leading-[1.6] text-ink">
                          {lesson.text}
                        </p>
                      </div>
                    </div>
                  </li>
                ))
              }
            </ul>
          </section>
        </div>

        <!-- ========== SIDEBAR ========== -->
        <aside class="lg:col-span-4 lg:sticky lg:top-28 lg:self-start space-y-6">
          <!-- Featured stat card -->
          <div
            class="rounded-3xl border-2 border-ink bg-ink text-base-soft p-6 relative overflow-hidden"
          >
            <div
              aria-hidden="true"
              class="absolute inset-0 opacity-10"
