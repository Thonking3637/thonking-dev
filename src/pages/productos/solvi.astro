<script>
  const openers = document.querySelectorAll<HTMLButtonElement>("[data-slide-open]");
  const closers = document.querySelectorAll<HTMLButtonElement>("[data-slide-close]");
  let savedScrollY = 0; let lastTrigger: HTMLButtonElement | null = null;
  const lockScroll = () => { savedScrollY = window.scrollY; const b = document.body; b.style.position = "fixed"; b.style.top = `-${savedScrollY}px`; b.style.left = "0"; b.style.right = "0"; b.style.width = "100%"; };
  const unlockScroll = () => { const b = document.body; b.style.position = ""; b.style.top = ""; b.style.left = ""; b.style.right = ""; b.style.width = ""; window.scrollTo({ top: savedScrollY, behavior: "instant" as ScrollBehavior }); };
  openers.forEach((btn) => btn.addEventListener("click", () => { const id = btn.dataset.slideOpen; const dlg = document.querySelector<HTMLDialogElement>(`dialog[data-slide="${id}"]`); if (dlg) { lastTrigger = btn; lockScroll(); dlg.showModal(); } }));
  closers.forEach((btn) => btn.addEventListener("click", () => btn.closest<HTMLDialogElement>("dialog")?.close()));
  document.querySelectorAll<HTMLDialogElement>("dialog.gdd-dialog").forEach((dlg) => { dlg.addEventListener("click", (e) => { if (e.target === dlg) dlg.close(); }); dlg.addEventListener("close", () => { unlockScroll(); if (lastTrigger) { lastTrigger.focus({ preventScroll: true }); lastTrigger = null; } }); });
</script>
<style>
  .gdd-dialog[open] { animation: gdd-dialog-in 220ms cubic-bezier(0.2, 0.8, 0.2, 1); }
  .gdd-dialog::backdrop { animation: gdd-backdrop-in 220ms ease-out; }
  @keyframes gdd-dialog-in { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }
  @keyframes gdd-backdrop-in { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .gdd-dialog[open], .gdd-dialog::backdrop { animation: none; } }
</style>
