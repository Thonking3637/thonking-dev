---
export type RevertSlideVariant = "title" | "gameplay" | "blackhole" | "credits";

interface Props {
  variant: RevertSlideVariant;
}
const { variant } = Astro.props;
---

<div
  class="relative h-full w-full flex flex-col overflow-hidden"
  style="padding: var(--slide-pad, 14px); background: radial-gradient(140% 90% at 50% 0%, #1b1040 0%, #08051a 70%); color: #ffe8d4;"
>
  <!-- decorative stars -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0"
  >
    {
      Array.from({ length: 36 }).map((_, i) => {
        const x = (i * 137) % 100;
        const y = (i * 61) % 100;
        const s = (i % 3) + 1;
        return (
          <span
            class="absolute rounded-full bg-white"
            style={`left: ${x}%; top: ${y}%; width: ${s}px; height: ${s}px; opacity: ${0.3 + (i % 4) * 0.15};`}
          />
        );
      })
    }
  </div>

  <!-- Header meta -->
  <div
    class="relative flex items-center justify-between font-mono uppercase tracking-[0.22em] text-[#7a6cc0]"
    style="font-size: var(--slide-meta, 7px);"
  >
    {variant === "title" && <span>Arcade · Pág 01</span>}
    {variant === "gameplay" && <span>Pág 02 · Gameplay</span>}
    {variant === "blackhole" && <span>Pág 03 · Gravity field</span>}
    {variant === "credits" && <span>Pág 04 · Créditos</span>}
    <span aria-hidden="true">— 2017</span>
  </div>

  <!-- Variant content -->
  {
    variant === "title" && (
      <div class="relative flex-1 flex flex-col items-center justify-center text-center">
        <div
          class="font-pixel font-bold leading-[0.9] text-white"
          style="font-size: var(--slide-title, 24px);"
        >
          REVERT
          <br />
          <span class="text-[#ff6b4a]">PONG</span>
        </div>
        <div
          class="mt-[6%] font-mono text-[#f4d35e] uppercase tracking-[0.25em] animate-pulse"
          style="font-size: var(--slide-meta, 7px);"
        >
          ▸ PRESS START
        </div>
        <div
          class="mt-[10%] font-mono text-white/60 text-center leading-[1.5]"
          style="font-size: var(--slide-body, 7px);"
        >
          <div>1 — 2 PLAYERS</div>
          <div class="mt-[4%]">ARCADE MODE</div>
          <div class="mt-[4%]">HI-SCORE · 98,400</div>
        </div>
      </div>
    )
  }

  {
    variant === "gameplay" && (
      <div class="relative flex-1 flex flex-col mt-[6%]">
        {/* HUD */}
        <div
          class="flex items-center justify-between font-mono text-[#f4d35e] uppercase tracking-[0.2em]"
          style="font-size: var(--slide-meta, 7px);"
        >
          <span>P1 · 0420</span>
          <span class="text-white">LEVEL 01</span>
          <span>P2 · 0380</span>
        </div>

        {/* Court */}
        <div class="relative flex-1 mt-[6%] mb-[6%] rounded-[2px]" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.15);">
          {/* dashed center line */}
          <div
            aria-hidden="true"
            class="absolute left-1/2 top-0 bottom-0 -translate-x-1/2 border-l border-dashed border-white/20"
          />

          {/* paddles */}
          <div class="absolute left-[4%] top-1/2 -translate-y-1/2 bg-[#f4d35e]" style="width: var(--slide-paddle-w, 3px); height: var(--slide-paddle-h, 32px);" />
          <div class="absolute right-[4%] top-[30%] bg-[#ff6b4a]" style="width: var(--slide-paddle-w, 3px); height: var(--slide-paddle-h, 32px);" />

          {/* ball */}
          <div
            class="absolute top-[45%] left-[55%] rounded-full bg-white"
            style="width: var(--slide-ball, 6px); height: var(--slide-ball, 6px); box-shadow: 0 0 8px rgba(255,255,255,0.6);"
          />

          {/* meteors */}
          <div class="absolute top-[18%] left-[28%] flex items-center gap-[3px]">
            <div class="rounded-full" style="width: var(--slide-meteor, 8px); height: var(--slide-meteor, 8px); background: radial-gradient(circle, #ff6b4a, #7a1f1f); box-shadow: 0 0 10px #ff6b4a80;" />
            <div class="h-[1.5px]" style="width: var(--slide-meteor-trail, 10px); background: linear-gradient(to right, #ff6b4a, transparent);" />
          </div>
          <div class="absolute top-[65%] left-[50%] flex items-center gap-[3px]">
            <div class="rounded-full" style="width: var(--slide-meteor-sm, 6px); height: var(--slide-meteor-sm, 6px); background: radial-gradient(circle, #f4d35e, #b89a3d); box-shadow: 0 0 8px #f4d35e80;" />
            <div class="h-[1.5px]" style="width: var(--slide-meteor-trail-sm, 8px); background: linear-gradient(to right, #f4d35e, transparent);" />
          </div>
          <div class="absolute top-[40%] left-[72%] flex items-center gap-[3px]">
            <div class="rounded-full" style="width: var(--slide-meteor-sm, 5px); height: var(--slide-meteor-sm, 5px); background: radial-gradient(circle, #937cff, #3d2b88); box-shadow: 0 0 6px #937cff80;" />
          </div>
        </div>

        {/* status */}
        <div
          class="flex items-center justify-center gap-[6px] font-mono text-white/70 uppercase tracking-[0.2em]"
          style="font-size: var(--slide-meta, 7px);"
        >
          <span class="inline-block size-[4px] rounded-full bg-[#f4d35e] animate-pulse" />
          Meteor field · active
        </div>
      </div>
    )
  }

  {
    variant === "blackhole" && (
      <div class="relative flex-1 flex flex-col items-center justify-center">
        {/* rings */}
        <div class="relative flex items-center justify-center" style="width: var(--slide-bh, 110px); height: var(--slide-bh, 110px);">
          <div class="absolute inset-0 rounded-full border border-[#937cff]/50 animate-pulse" />
          <div class="absolute inset-[8%] rounded-full border border-[#937cff]/35" />
          <div class="absolute inset-[16%] rounded-full border border-[#937cff]/25" />
          <div class="absolute inset-[25%] rounded-full border border-[#f4d35e]/20" />
          {/* core */}
          <div
            class="absolute inset-[34%] rounded-full"
            style="background: radial-gradient(circle, #000 0%, #1b1040 70%, transparent 100%); box-shadow: 0 0 30px #937cff;"
          />
          {/* ball being pulled */}
          <div
            class="absolute top-[12%] left-[18%] rounded-full bg-white animate-pulse"
            style="width: var(--slide-ball, 5px); height: var(--slide-ball, 5px);"
          />
        </div>

        <div
          class="mt-[6%] font-pixel font-bold text-[#f4d35e] uppercase tracking-[0.2em] animate-pulse"
          style="font-size: var(--slide-sub, 10px);"
        >
          GRAVITY FIELD
        </div>
        <div
          class="mt-[3%] font-mono text-white/60 uppercase tracking-[0.2em]"
          style="font-size: var(--slide-meta, 7px);"
        >
          Teleporting ball · 3s
        </div>
      </div>
    )
  }

  {
    variant === "credits" && (
      <div class="relative flex-1 flex flex-col items-center justify-center text-center">
        <div
          class="font-pixel font-bold leading-[0.95] text-white"
          style="font-size: var(--slide-title, 22px);"
        >
          GAME
          <br />
          <span class="text-[#f4d35e]">OVER</span>
        </div>
        <div
          class="mt-[6%] font-mono text-[#ff6b4a] uppercase tracking-[0.22em]"
          style="font-size: var(--slide-meta, 7px);"
        >
          ▸ Thanks for playing
        </div>

        <ul
          class="mt-[10%] flex flex-col text-center font-mono text-white/70"
          style="gap: var(--slide-gap-sm, 3px); font-size: var(--slide-body, 7px);"
        >
          <li>
            <span class="text-[#8b7e6a]">DESIGN · CODE</span>
            <span class="block text-white">Gabriel Ramírez</span>
          </li>
          <li class="mt-[6%]">
            <span class="text-[#8b7e6a]">CLIENT</span>
            <span class="block text-white">Virtual Magic Park</span>
          </li>
          <li class="mt-[6%]">
            <span class="text-[#8b7e6a]">YEAR · STACK</span>
            <span class="block text-white">2017 · Unity · C#</span>
          </li>
        </ul>
      </div>
    )
  }

  <!-- Footer -->
  <div
    class="relative mt-auto pt-[4%] border-t border-white/10 flex items-center justify-between font-mono uppercase tracking-[0.22em] text-[#7a6cc0]"
    style="font-size: var(--slide-footer, 6px);"
  >
    <span>THONKING · Revert Pong</span>
    <span class="text-[#f4d35e]">v1.0</span>
  </div>
</div>
