---
import { getCollection } from "astro:content";
import ProductVisual from "./ProductVisual.astro";

const products = (await getCollection("products")).sort(
  (a, b) => a.data.order - b.data.order
);

const statusColor: Record<string, string> = {
  live: "bg-primary",
  wip: "bg-secondary",
  beta: "bg-pink",
  locked: "bg-ink",
  commercial: "bg-muted",
};
---

<section
  id="trabajo"
  class="relative isolate py-24 md:py-32 overflow-hidden"
>
  <div
    aria-hidden="true"
    class="pointer-events-none select-none absolute inset-x-0 top-8 flex justify-center"
  >
    <span
      class="hero-stroke font-pixel text-[18vw] md:text-[14vw] leading-none tracking-tight opacity-[0.06]"
      >SELECTED WORK</span
    >
  </div>

  <div class="relative mx-auto w-full max-w-[1280px] px-6 md:px-10">
    <!-- Section header -->
    <header
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16"
    >
      <div>
        <div
          class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60"
        >
          <span class="size-1.5 rounded-full bg-primary"></span>
          § 03 · Trabajo
        </div>
        <h2
          class="mt-3 font-display font-black text-6xl md:text-7xl lg:text-8xl leading-[0.9] tracking-[-0.03em]"
        >
          Lo que <span class="relative inline-block">
            envío
            <svg
              aria-hidden="true"
              viewBox="0 0 300 28"
              preserveAspectRatio="none"
              class="absolute -bottom-1.5 left-0 w-full h-5"
            >
              <path
                d="M4 16 C 60 4, 140 22, 220 12 S 296 4, 296 16"
                stroke="#ff6b4a"
                stroke-width="8"
                stroke-linecap="round"
                fill="none"
              />
            </svg>
          </span>
        </h2>
      </div>
      <p class="max-w-sm text-base text-muted leading-relaxed">
        Algunos ya en producción, otros en beta privada, uno bajo NDA. Todos los
        juego, uso y reviso personalmente antes de que salgan.
      </p>
    </header>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
      {
        products.map((p) => (
          <a
            id={`producto-${p.id}`}
            href={`/productos/${p.id}`}
            class:list={[
              "group relative flex flex-col rounded-2xl border border-ink/10 bg-base-soft overflow-hidden shadow-[0_8px_30px_-12px_rgba(26,24,21,0.18)] hover:-translate-y-1 hover:shadow-[0_18px_40px_-12px_rgba(26,24,21,0.25)] transition-all duration-300 scroll-mt-28",
              p.data.span === 2 ? "md:col-span-2" : "",
            ]}
          >
            {/* Visual */}
            <div class="relative h-[220px] md:h-[240px] overflow-hidden">
              <ProductVisual
                image={p.data.image}
                placeholder={p.data.placeholder}
                title={p.data.title}
              />
              {/* status pill */}
              <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-base-soft/95 backdrop-blur-sm px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-ink z-10">
                <span
                  class:list={[
                    "size-1.5 rounded-full",
                    statusColor[p.data.status],
                  ]}
                />
                {p.data.statusLabel}
              </div>
              {/* arrow */}
              <div class="absolute top-3 right-3 grid size-8 place-items-center rounded-full bg-base-soft/95 backdrop-blur-sm text-ink transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 z-10">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-4"
                >
                  <path d="M7 17L17 7M9 7h8v8" />
                </svg>
              </div>
            </div>

            {/* Content */}
            <div class="flex-1 p-5 md:p-6 flex flex-col">
              <h3 class="font-display font-black text-2xl md:text-[28px] leading-tight tracking-tight">
                {p.data.title}
              </h3>
              <p class="mt-2 text-sm text-muted leading-relaxed">
                {p.data.tagline}
              </p>
              {p.data.note && (
                <p class="mt-1.5 font-mono text-[10px] uppercase tracking-[0.16em] text-ink/50">
                  · {p.data.note}
                </p>
              )}
              <ul class="mt-auto pt-4 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-ink/60">
                {p.data.tags.map((t) => (
                  <li class="rounded-full border border-ink/10 bg-base px-2 py-0.5">
                    {t}
                  </li>
                ))}
              </ul>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
